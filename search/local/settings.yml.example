use_default_settings:
  engines:
    keep_only:
      - google
      - duckduckgo
      - brave
      - startpage
      - qwant
      - mojeek
      - wikipedia
      - bing

general:
  instance_name: "MirAI Search Local"
  enable_metrics: false

search:
  safe_search: 1
  autocomplete: "google"
  formats:
    - html
    - json

server:
  limiter: false
  image_proxy: true

ui:
  default_locale: "fr"
  query_in_title: false

valkey:
  url: valkey://search-valkey:6379/0

outgoing:
  request_timeout: 10.0
  max_request_timeout: 20.0
  retries: 2
  pool_connections: 50
  pool_maxsize: 10
  enable_http2: true
  # Rotating proxy (uncomment and set credentials)
  # proxies:
  #   all://:
  #     - http://user:key@proxy-host:3128

engines:
  - name: google
    weight: 1.8
  - name: startpage
    weight: 1.5
  - name: qwant
    weight: 1.4
  - name: duckduckgo
    weight: 1.2
  - name: mojeek
    weight: 1.0
  - name: wikipedia
    weight: 0.8
  - name: bing
    weight: 0.7
  - name: brave
    weight: 0.3
    disabled: true
  - name: braveapi
    engine: braveapi
    api_key: CHANGE_ME
    shortcut: brapi
    weight: 0.4
