{
  "realm": "openwebui",
  "enabled": true,
  "sslRequired": "none",
  "displayName": "Open WebUI",
  "registrationAllowed": false,
  "rememberMe": true,
  "resetPasswordAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Standard Open WebUI user"
      },
      {
        "name": "admin",
        "description": "Open WebUI administrator"
      }
    ]
  },
  "clients": [
    {
      "clientId": "openwebui",
      "name": "Open WebUI",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "${KEYCLOAK_CLIENT_SECRET}",
      "redirectUris": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*",
        "https://${OPENWEBUI_HOST}/*",
        "https://assistant.fake-domain.name/*",
        "https://genial.fake-domain.name/*",
        "https://genial.fake-domain.name/oauth2/callback"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://127.0.0.1:3000",
        "https://${OPENWEBUI_HOST}",
        "https://assistant.fake-domain.name",
        "https://genial.fake-domain.name"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "attributes": {
        "post.logout.redirect.uris": "https://${OPENWEBUI_HOST}/*"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "groups"
          }
        }
      ]
    },
    {
      "clientId": "graphrag-viewer",
      "name": "GraphRAG Viewer",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "redirectUris": [
        "http://localhost:8081/*",
        "http://127.0.0.1:8081/*",
        "https://${BRIDGE_HOST}/*"
      ],
      "webOrigins": [
        "http://localhost:8081",
        "http://127.0.0.1:8081",
        "https://${BRIDGE_HOST}"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:8081/* http://127.0.0.1:8081/* https://${BRIDGE_HOST}/*"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "groups"
          }
        }
      ]
    },
    {
      "clientId": "corpus-manager",
      "name": "Corpus Manager",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "redirectUris": [
        "http://localhost:8084/*",
        "http://127.0.0.1:8084/*",
        "https://${CORPUS_MANAGER_HOST}/*"
      ],
      "webOrigins": [
        "http://localhost:8084",
        "http://127.0.0.1:8084",
        "https://${CORPUS_MANAGER_HOST}"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:8084/* http://127.0.0.1:8084/* https://${CORPUS_MANAGER_HOST}/*"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "groups"
          }
        }
      ]
    },
    {
      "clientId": "bootstrap-iassistant",
      "name": "Assistant Mirai LibreOffice",
      "description": "Client public PKCE pour le plug-in LibreOffice Mirai",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "frontchannelLogout": false,
      "redirectUris": [
        "http://localhost:*",
        "http://127.0.0.1:*"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "access.token.lifespan": "300",
        "post.logout.redirect.uris": "+"
      }
    }
  ],
